{
  "name": "@susyabashti/thoth",
  "version": "0.0.2",
  "main": "src/index.ts",
  "module": "src/index.ts",
  "scripts": {
    "build": "bun build ./src/index.ts --target=bun --outdir ./dist",
    "prepublishOnly": "bun build ./src/index.ts --target=bun --outfile ./dist/index.js"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "5"
  },
  "bin": {
    "thoth": "dist/index.js"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module"
}
